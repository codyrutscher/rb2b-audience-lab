# === LOGIN REQUIRES THESE (Supabase Auth) ===
# Get from: Supabase Dashboard → Project Settings → API
# Anon key: safe for client, used for auth (sign in/sign up)
# Service role: server-only, bypasses RLS
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-dashboard

# Postgres — Supabase → Settings → Database → Connection string
# Use pooler for Prisma: aws-0-REGION.pooler.supabase.com:6543
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Reactivate (knowledge base, embeddings, email)
# Audiencelab pixel API (Pixel_Fields.md): https://api.audiencelab.io
AUDIENCELAB_API_KEY=
HUGGINGFACE_TOKEN=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=retarget-mvp
COPY_GENERATION_MODEL=meta-llama/Llama-3.2-3B-Instruct
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TRACKING_SCRIPT_URL=http://localhost:3000/track.js

# Optional
IP_GEOLOCATION_API_KEY=
