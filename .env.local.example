# Supabase (all point to the same project/database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres for Prisma/Reactivate — same DB as above; Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Reactivate (optional - for knowledge base, embeddings, email)
HUGGINGFACE_TOKEN=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TRACKING_SCRIPT_URL=http://localhost:3000/track.js

# Optional: IP Geolocation API (ipapi.co or similar)
IP_GEOLOCATION_API_KEY=optional-api-key
