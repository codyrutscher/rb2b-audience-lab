// Reactivate tables: rt_* prefix to avoid collision with rb2b segments
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RtAccount {
  id          String   @id @default(uuid())
  workspaceId String   @unique @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  webhooks          RtWebhook[]
  contacts          RtContact[]
  segments          RtSegment[]
  knowledgeBanks    RtKnowledgeBank[]
  segmentCampaigns  RtSegmentCampaign[]
  emailSends        RtEmailSend[]
  unsubscribes      RtAccountUnsubscribe[]
  pixels            RtPixel[]
  pixelSchedules    RtPixelSchedule[]
  emailTemplates    RtEmailTemplate[]

  @@map("rt_accounts")
}

model RtPixel {
  id                   String   @id @default(uuid())
  accountId            String   @map("account_id")
  account              RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name                 String   @map("name")
  websiteName          String   @map("website_name")
  websiteUrl           String   @map("website_url")
  webhookUrl           String?  @map("webhook_url")
  version              String   @default("v4") @map("version")
  audiencelabPixelId   String?  @map("audiencelab_pixel_id")
  audiencelabInstallUrl String? @map("audiencelab_install_url")
  audiencelabApiKey    String?  @map("audiencelab_api_key")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  contactEvents       RtContactEvent[]
  schedule             RtPixelSchedule?

  @@map("rt_pixels")
}

model RtPixelSchedule {
  id           String    @id @default(uuid())
  pixelId      String    @unique @map("pixel_id")
  pixel        RtPixel   @relation(fields: [pixelId], references: [id], onDelete: Cascade)
  accountId    String    @map("account_id")
  account      RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  intervalType String    @map("interval_type")
  intervalValue Int     @map("interval_value")
  enabled      Boolean   @default(true)
  lastRunAt    DateTime? @map("last_run_at")
  nextRunAt    DateTime  @default(now()) @map("next_run_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  runs         RtScheduleRun[]

  @@map("rt_pixel_schedules")
}

model RtScheduleRun {
  id              String    @id @default(uuid())
  scheduleId      String    @map("schedule_id")
  schedule        RtPixelSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  status          String    @default("running")
  pagesFetched    Int       @default(0) @map("pages_fetched")
  contactsUpserted Int      @default(0) @map("contacts_upserted")
  eventsInserted  Int       @default(0) @map("events_inserted")
  eventsSkipped   Int       @default(0) @map("events_skipped")
  contactsEnqueued Int      @default(0) @map("contacts_enqueued")
  error           String?   @map("error")

  @@map("rt_schedule_runs")
}

model RtWebhook {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  account   RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rt_webhooks")
}

model RtContact {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  account   RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  edid      String?  @map("edid")
  hemSha256 String?  @map("hem_sha256")
  pixelData Json?    @default("{}") @map("pixel_data")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  events    RtContactEvent[]
  segmentState RtContactSegmentState?
  emailSends RtEmailSend[]

  @@unique([accountId, email])
  @@map("rt_contacts")
}

model RtContactEvent {
  id             String    @id @default(uuid())
  accountId      String    @map("account_id")
  contactId      String    @map("contact_id")
  contact        RtContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pixelId        String?   @map("pixel_id")
  pixel          RtPixel?  @relation(fields: [pixelId], references: [id], onDelete: SetNull)
  url            String?
  fullUrl        String?   @map("full_url")
  referrerUrl    String?   @map("referrer_url")
  eventType      String    @map("event_type")
  ts             DateTime
  metadata       Json?     @default("{}")
  resolution     Json?     @default("{}")
  sourceEventKey String?   @unique @map("source_event_key")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("rt_contact_events")
}

model RtJob {
  id        String   @id @default(uuid())
  name      String
  payload   Json
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  error     String?

  @@map("rt_jobs")
}

model RtSegment {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  account       RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name          String
  priority      Int      @default(999)
  isSuppression        Boolean  @default(false) @map("is_suppression")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  rules         RtSegmentRule[]
  ruleGroups    RtSegmentRuleGroup[]
  contactStates RtContactSegmentState[]
  segmentCampaigns RtSegmentCampaign[]

  @@map("rt_segments")
}

model RtSegmentRuleGroup {
  id        String   @id @default(uuid())
  segmentId String   @map("segment_id")
  segment   RtSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  logicalOp String   @map("logical_op")
  groupOrder Int     @default(0) @map("group_order")
  rules     RtSegmentRule[]

  @@map("rt_segment_rule_groups")
}

model RtSegmentRule {
  id        String   @id @default(uuid())
  segmentId String   @map("segment_id")
  segment   RtSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  groupId   String?  @map("group_id")
  group     RtSegmentRuleGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ruleType  String   @map("rule_type")
  ruleValue String   @map("rule_value")
  field     String?
  operator  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rt_segment_rules")
}

model RtContactSegmentState {
  id          String   @id @default(uuid())
  contactId   String   @unique @map("contact_id")
  contact     RtContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segmentId   String?  @map("segment_id")
  segment     RtSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  evaluatedAt DateTime @default(now()) @map("evaluated_at")

  @@map("rt_contact_segment_state")
}

model RtKnowledgeBank {
  id          String    @id @default(uuid())
  accountId   String    @map("account_id")
  account     RtAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  documents   RtKnowledgeDocument[]
  segmentCampaigns RtSegmentCampaign[]
  emailTemplates RtEmailTemplate[]

  @@map("rt_knowledge_banks")
}

model RtEmailTemplate {
  id             String    @id @default(uuid())
  accountId      String    @map("account_id")
  account        RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  knowledgeBankId String  @map("knowledge_bank_id")
  knowledgeBank   RtKnowledgeBank @relation(fields: [knowledgeBankId], references: [id], onDelete: Cascade)
  copyPrompt     String?   @map("copy_prompt") @db.Text
  subjectTemplate String  @map("subject_template")
  templateId     String    @map("template_id")
  queryHint      String?   @map("query_hint")
  ctaUrl         String?   @map("cta_url")
  ctaLabel       String?   @map("cta_label")
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  segmentCampaigns RtSegmentCampaign[]

  @@map("rt_email_templates")
}

model RtKnowledgeDocument {
  id              String   @id @default(uuid())
  knowledgeBankId String   @map("knowledge_bank_id")
  knowledgeBank   RtKnowledgeBank @relation(fields: [knowledgeBankId], references: [id], onDelete: Cascade)
  filename        String
  status          String   @default("pending")
  hash            String?
  storagePath     String?  @map("storage_path")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  chunks          RtKnowledgeChunk[]

  @@map("rt_knowledge_documents")
}

model RtKnowledgeChunk {
  id              String   @id
  knowledgeBankId String   @map("knowledge_bank_id")
  documentId      String   @map("document_id")
  chunkIndex      Int      @map("chunk_index")
  text            String   @db.Text
  metadata        Json?    @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  document        RtKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("rt_knowledge_chunks")
}

model RtSegmentCampaign {
  id                   String    @id @default(uuid())
  accountId            String    @map("account_id")
  account              RtAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  segmentId            String    @map("segment_id")
  segment              RtSegment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  knowledgeBankId      String    @map("knowledge_bank_id")
  knowledgeBank        RtKnowledgeBank @relation(fields: [knowledgeBankId], references: [id], onDelete: Cascade)
  emailTemplateId      String?   @map("email_template_id")
  emailTemplate        RtEmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  templateId           String    @map("template_id")
  subjectText          String    @map("subject_text")
  ctaUrl               String?   @map("cta_url")
  ctaLabel             String?   @map("cta_label")
  queryHint            String?   @map("query_hint")
  copyPrompt           String?   @map("copy_prompt") @db.Text
  emailFieldMap        String?   @map("email_field_map")
  triggerType          String    @default("on_segment_update") @map("trigger_type")
  triggerIntervalType  String?   @map("trigger_interval_type")
  triggerIntervalValue Int?      @map("trigger_interval_value")
  enabled              Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  emailSends           RtEmailSend[]

  @@map("rt_segment_campaigns")
}

model RtEmailSend {
  id                 String   @id @default(uuid())
  accountId          String   @map("account_id")
  account            RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId          String   @map("contact_id")
  contact            RtContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segmentCampaignId  String   @map("segment_campaign_id")
  segmentCampaign    RtSegmentCampaign @relation(fields: [segmentCampaignId], references: [id], onDelete: Cascade)
  templateId         String   @map("template_id")
  emailTemplateId    String?  @map("email_template_id")
  resolvedEmail     String?  @map("resolved_email")
  resendMessageId    String?  @map("resend_message_id")
  status             String   @default("sent")
  error              String?
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("rt_email_sends")
}

model RtAccountUnsubscribe {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  account   RtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  @@unique([accountId, email])
  @@map("rt_account_unsubscribes")
}
